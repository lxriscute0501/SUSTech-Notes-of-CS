int M[10];
int sink(int x){return 0;}
int main() {
    M == M;                       // unmatchedTypeForBinaryOP? No — both same array type, but array not allowed in == unless pointer. Per [2.2.12]: operands must be int/pointer. M is array → unexpectedType.
    int x;
    x = M;                        // unmatchedTypeForBinaryOP (int = array)
    sink(M);                      // badParamType
    ++(1 + 2);                    // lvalueRequired
    M + 2;
    M - 1;
    return 0;
}